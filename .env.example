# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=           # OpenAI API key for LLM calls (required)
OPENAI_ANALYSIS_MODEL=    # Model for document analysis in knowledge base (optional, defaults to gpt-4o-mini)

# ── Tools ─────────────────────────────────────────────────────────────────────
# https://newsapi.org/account
NEWS_API_TOKEN=           # NewsAPI token for live news reading (optional — news tool disabled if not set)
# Comma-separated list of tool groups to disable (optional). All enabled by default.
# Valid keys: zapier, cronjob, news, ui, file, cmd, memory, knowledge_base, jira, notifications
# Example: DISABLE_TOOLS=zapier,cmd
DISABLE_TOOLS=

# ── Zapier MCP ────────────────────────────────────────────────────────────────
ZAPIER_MCP_URL=           # Zapier MCP server URL (required when zapier tool group is enabled)
ZAPIER_MCP_TOKEN=         # Zapier MCP bearer token (required when zapier tool group is enabled)

# ── UI Sections ───────────────────────────────────────────────────────────────
# Comma-separated list of UI sections to disable (optional). All enabled by default.
# Valid keys: ai, jobs, mail, knowledge-base, cronjobs, notifications
# Example: DISABLE_SECTIONS=mail,jobs
DISABLE_SECTIONS=

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=tanstack_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/tanstack_ai

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# Internal Docker hostname when running in Docker; use localhost:9200 for local dev
ELASTICSEARCH_URL=http://localhost:9200
# WSL2 note: if the elasticsearch container exits immediately, run:
#   sudo sysctl -w vm.max_map_count=262144
# on the WSL2 host (or add it to /etc/sysctl.conf for persistence)

# ── Services ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000   # Base URL of the web app, used by workers to call /api/chat-sync

# ── Authentication ────────────────────────────────────────────────────────────
SESSION_SECRET=              # Required: random string >= 32 chars. Generate: openssl rand -base64 32

# ── Telegram (Communication Gateway) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=       # Bot token from @BotFather
TELEGRAM_BOT_USERNAME=    # Bot username without the leading @
TELEGRAM_ADMIN_CHAT_ID=   # (Optional) Chat ID to receive bot startup notifications

# ── Yahoo Mail (IMAP ingestion) ────────────────────────────────────────────────
YAHOO_IMAP_USER=          # Full Yahoo email address (e.g. you@yahoo.com)
YAHOO_IMAP_PASSWORD=      # App Password from myaccount.yahoo.com → Security → App passwords
                          # IMPORTANT: This is NOT your Yahoo login password. It is a
                          # 16-character app-specific password. Yahoo requires this for
                          # third-party IMAP access when 2FA is enabled.
YAHOO_MAIL_FOLDERS=INBOX  # Comma-separated folder names to poll (e.g. "INBOX,Jobs,Recruiters")
YAHOO_MAIL_MAX_EMAILS=50  # Maximum emails to fetch per ingestion call

# ── PDF Resume Generation ──────────────────────────────────────────────────────
CHROME_EXECUTABLE_PATH=   # Path to Chrome executable for PDF generation (optional — defaults to macOS path)
